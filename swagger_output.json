  "definitions": {
    "Socio": {
      "type": "object",
      "properties": {
        "nombre": {
          "type": "string",
          "example": "Pablo"
        },
        "apellido": {
          "type": "string",
          "example": "Torres"
        },
        "foto": {
          "type": "string",
          "example": "https://img.magnific.com/vector-premium/imagen-perfil-avatar-hombre-aislada-fondo-imagen-profil-avatar-hombre_1293239-4841.jpg?semt=ais_hybrid&w=740&q=80"
        },
        "dni": {
          "type": "string",
          "example": "12345678"
        },
        "numeroSocio": {
          "type": "number",
          "example": 1001
        },
        "activo": {
          "type": "boolean",
          "example": true
        }
      }
    },
    "Transaccion": {
      "type": "object",
      "properties": {
        "idiomaOrigen": {
          "type": "string",
          "example": "es"
        },
        "textoOrigen": {
          "type": "string",
          "example": "Hola Mundo"
        },
        "idiomaDestino": {
          "type": "string",
          "example": "en"
        },
        "textoDestino": {
          "type": "string",
          "example": "Hello world"
        },
        "emailCliente": {
          "type": "string",
          "example": "cliente@gmail.com"
        }
      }
    },
    "Empleado": {
      "type": "object",
      "properties": {
        "apellido": {
          "type": "string",
          "example": "Cristina"
        },
        "nombre": {
          "type": "string",
          "example": "Kirchnner"
        },
        "dni": {
          "type": "string",
          "example": "87654321"
        },
        "email": {
          "type": "string",
          "example": "Cristina@gmail.com"
        }
      }
    },
    "Publicacion": {
      "type": "object",
      "properties": {
        "titulo": {
          "type": "string",
          "example": "Investigacion de patitos"
        },
        "contenido": {
          "type": "string",
          "example": "patitos"
        },
        "imagenAsociada": {
          "type": "string",
          "example": "base64"
        },
        "fechaPublicacion": {
          "type": "string",
          "example": "2026-06-15"
        },
        "vigente": {
          "type": "boolean",
          "example": true
        },
        "propietario": {
          "type": "object",
          "properties": {
            "id": {
              "type": "number",
              "example": 1
            }
          }
        }
